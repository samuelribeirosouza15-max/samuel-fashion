/* Estilos da Tela de Autenticação */
.auth-container {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: var(--bg); display: flex; justify-content: center; align-items: center; z-index: 3000;
}
.auth-box {
    background: var(--card-bg); padding: 40px; border-radius: 24px;
    border: 1px solid var(--border); width: 100%; max-width: 400px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
}
.auth-box input, .auth-box select {
    width: 100%; padding: 12px; margin-top: 12px; border-radius: 12px;
    border: 1px solid var(--border); background: var(--bg); color: var(--text); outline: none;
}

/* Painel Admin */
.admin-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 40px; margin-top: 20px;
}
.inventory-item {
    display: flex; justify-content: space-between; align-items: center;
    padding: 12px; border-bottom: 1px solid var(--border); background: var(--card-bg); border-radius: 8px; margin-bottom: 8px;
}
.quantity-control {
    display: flex; align-items: center; gap: 10px; margin: 5px 0;
}
.btn-qty {
    background: var(--border); border: none; width: 24px; height: 24px; border-radius: 6px; cursor: pointer; font-weight: bold; color: var(--text);
}
